<%- layout("layouts/boilerplate.ejs") %>

<body>
  <div class="container my-5">
    <div class="list card p-4 mx-auto shadow-lg text-center" style="max-width: 600px;">
      <h2 class="mb-3 listing-title">
        <%= list.title %>
      </h2>

      <img src="<%= list.image.url %>" alt="Image" class="img-fluid rounded mb-3 listing-img">

      <h3 class="mb-2 owner-text">Owner: <i><b><%= list.owner.username %></b></i></h3>

      <p class="mb-2"><b>Description:</b> <%= list.description %></p>
      <p class="mb-2"><b>Location:</b> <%= list.location %>, <%= list.country %></p>
      <p class="mb-4"><b>Price:</b> Rs/- <%= list.price.toLocaleString("en-PK") %></p>

      <% if (curruser && curruser._id.equals(list.owner._id)) { %>
        <div class="d-flex justify-content-center gap-3">
          <a href="/listings/<%= list._id %>/edit" class="btn btn-warning">Update Listing</a>

          <form method="POST" action="/listings/<%= list._id %>?_method=DELETE">
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>
      <% } %>
    </div>

    <hr class="my-5">

    <% if (curruser) { %>
      <h3 class="text-center mb-4 feedback-heading">Give Feedback to Listing</h3>

      <form action="/listings/<%= list._id %>/reviews" method="POST" novalidate
        class="card p-4 shadow-lg mx-auto feedback-card">

        <fieldset class="starability-heartbeat mb-3">
          <legend>Rating:</legend>
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
            aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>

        <div class="mb-4 text-start">
          <label class="form-label fw-semibold">Comment</label>
          <textarea name="review[comment]" class="form-control" rows="4"
            placeholder="Write comments for the Listing..." required></textarea>
        </div>

        <div class="text-center">
          <button type="submit" class="btn btn-primary px-4 rounded-pill">Submit Feedback</button>
        </div>
      </form>
    <% } %>

    <div class="reviews mt-5 text-center">
      <h3 class="mb-4 review-heading">User Reviews</h3>

      <% if (list.reviews && list.reviews.length > 0) { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
          <% list.reviews.forEach(review => { %>
            <div class="col">
              <div class="card review-card h-100">
                <div class="card-body text-start">
                  <h5>@<i><%= review.author.username %></i></h5>
                  <h6 class="starability-result" data-rating="<%= review.rating %>"></h6>
                  <p><%= review.comment %></p>

                  <% if (curruser && curruser._id.equals(review.author._id)) { %>
                    <form method="POST"
                      action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted fst-italic">No reviews yet.</p>
      <% } %>
    </div>
  </div>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #301B22, #4B2C35, #DBC4B4);
      color: #DBC4B4;
      min-height: 100vh;
      margin: 0;
      background-attachment: fixed;
    }

    h2, h3, h5, h6, p {
      color: #DBC4B4;
    }

    .card {
      background: rgba(48, 27, 34, 0.6);
      border: 1px solid #301B22;
      border-radius: 16px;
      color: #DBC4B4;
      backdrop-filter: blur(8px);
      transition: all 0.3s ease;
    }

    .card:hover {
      box-shadow: 0 8px 25px rgba(48, 27, 34, 0.5);
      transform: translateY(-3px);
    }

    .listing-img {
      max-height: 300px;
      object-fit: cover;
      border-radius: 12px;
      border: 2px solid #301B22;
    }

    .btn-warning {
      background-color: #DBC4B4;
      color: #301B22;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-warning:hover {
      background-color: #301B22;
      color: #DBC4B4;
      box-shadow: 0 4px 12px rgba(48, 27, 34, 0.3);
      transform: translateY(-2px);
    }

    .btn-danger {
      background-color: #872C3B;
      border: none;
      color: #DBC4B4;
      font-weight: 600;
      border-radius: 8px;
      transition: all 0.3s ease;
    }

    .btn-danger:hover {
      background-color: #5C1F27;
      transform: translateY(-2px);
    }

    .btn-primary {
      background-color: #DBC4B4;
      color: #301B22;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-primary:hover {
      background-color: #301B22;
      color: #DBC4B4;
      box-shadow: 0 4px 15px rgba(48, 27, 34, 0.6);
      transform: translateY(-2px);
    }

    .feedback-heading {
      color: #DBC4B4;
      font-weight: 600;
    }

    .feedback-card {
      background: rgba(48, 27, 34, 0.6);
      border: 1px solid #301B22;
      border-radius: 16px;
      color: #DBC4B4;
      backdrop-filter: blur(8px);
    }

    textarea.form-control {
      background-color: rgba(219, 196, 180, 0.1);
      border: 1px solid #301B22;
      color: #DBC4B4;
      border-radius: 10px;
    }

    textarea.form-control:focus {
      background-color: rgba(219, 196, 180, 0.15);
      border-color: #301B22;
      box-shadow: 0 0 8px #301B22;
    }

    .review-card {
      transition: 0.3s ease;
    }

    .review-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 4px 15px rgba(48, 27, 34, 0.3);
    }

    .review-heading {
      color: #DBC4B4;
      font-weight: 600;
    }

    @media (max-width: 576px) {
      .card {
        padding: 1.5rem;
      }

      .listing-img {
        max-height: 220px;
      }

      h2 {
        font-size: 1.5rem;
      }
    }
  </style>
</body>
