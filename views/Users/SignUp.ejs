<%- layout("layouts/boilerplate") %>

<body>
  <div class="container my-5">
    <h1 class="text-center mb-4">Create a New Account</h1>

    <form novalidate method="POST" action="/signup" class="card p-4 mx-auto shadow-lg needs-validation" style="max-width: 600px;">
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input id="username" name="username" type="text" class="form-control" placeholder="JohnDoe" required>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input id="email" name="email" type="email" class="form-control" placeholder="example@gmail.com" required>
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input id="password" name="password" type="password" class="form-control" placeholder="Enter password" required>
      </div>

      <div class="text-center">
        <button class="btn btn-success px-4" type="submit">Register</button>
      </div>

      <div class="text-center mt-3">
        <a href="/login">Already have an account?</a>
      </div>
    </form>
  </div>

  <style>
    /* ======= Base Styles ======= */
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #301B22, #4B2C35, #DBC4B4);
      color: #DBC4B4;
      min-height: 100vh;
      background-attachment: fixed;
      margin: 0;
    }

    h1 {
      font-weight: 700;
      color: #DBC4B4;
      letter-spacing: 0.5px;
    }

    /* ======= Card Styling ======= */
    .card {
      background: rgba(48, 27, 34, 0.65);
      border: 1px solid rgba(219, 196, 180, 0.3);
      border-radius: 16px;
      color: #DBC4B4;
      backdrop-filter: blur(8px);
      transition: all 0.3s ease;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(48, 27, 34, 0.6);
    }

    /* ======= Labels ======= */
    .form-label {
      color: #DBC4B4;
      font-weight: 500;
    }

    /* ======= Inputs ======= */
    .form-control {
      background-color: rgba(219, 196, 180, 0.08);
      border: 1px solid rgba(219, 196, 180, 0.3);
      color: #fff;
      border-radius: 10px;
      transition: all 0.3s ease;
    }

    .form-control::placeholder {
      color: rgba(255, 255, 255, 0.7);
    }

    .form-control:focus {
      background-color: rgba(219, 196, 180, 0.12);
      border-color: #DBC4B4;
      box-shadow: 0 0 8px #DBC4B4;
      color: #fff;
    }

    /* ======= Buttons ======= */
    .btn-success {
      background-color: #DBC4B4;
      color: #301B22;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-success:hover {
      background-color: #301B22;
      color: #DBC4B4;
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(219, 196, 180, 0.4);
    }

    /* ======= Links ======= */
    a {
      text-decoration: none;
      color: #DBC4B4;
      font-weight: 500;
      transition: all 0.3s ease;
    }

    a:hover {
      color: #fff;
      text-decoration: underline;
    }

    /* ======= Responsive ======= */
    @media (max-width: 576px) {
      h1 {
        font-size: 1.6rem;
      }

      .card {
        padding: 1.5rem;
      }
    }
  </style>
</body>
