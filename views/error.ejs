<%- layout("/layouts/boilerplate.ejs") %>

<body>
  <div class="d-flex justify-content-center align-items-center vh-100">
    <div class="alert custom-alert text-center shadow-lg p-5 mx-3" role="alert">
      <h2 class="fw-bold mb-3">⚠️ Oops! Something Went Wrong</h2>
      <p class="mb-4 fs-5"><%= message %></p>
      <button type="button" onclick="window.history.back()" class="btn btn-primary px-4">Go Back</button>
    </div>
  </div>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #301B22, #4B2C35, #DBC4B4);
      color: #DBC4B4;
      min-height: 100vh;
      margin: 0;
      background-attachment: fixed;
    }

    .custom-alert {
      background: rgba(48, 27, 34, 0.7);
      border: 1px solid rgba(219, 196, 180, 0.4);
      color: #DBC4B4;
      border-radius: 16px;
      backdrop-filter: blur(10px);
      max-width: 600px;
      transition: all 0.3s ease;
    }

    .custom-alert:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(48, 27, 34, 0.6);
    }

    .btn-primary {
      background-color: #DBC4B4;
      color: #301B22;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .btn-primary:hover {
      background-color: #301B22;
      color: #DBC4B4;
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(219, 196, 180, 0.4);
    }

    /* Responsive */
    @media (max-width: 576px) {
      .custom-alert {
        padding: 2rem 1.5rem;
      }

      h2 {
        font-size: 1.4rem;
      }

      p {
        font-size: 1rem;
      }
    }
  </style>
</body>
